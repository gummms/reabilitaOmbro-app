rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────────────────
    // Any authenticated user can read user documents (needed for auth gate role check).
    // A user can write their own document; a doctor can write any patient document.
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid
                   || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "doctor";

      // ── Per-patient levels subcollection ────────────────────────────────────
      // Patients can only read their own levels.
      // Doctors can read any patient's levels and write (create/update/delete) them.
      match /levels/{levelId} {
        allow read: if request.auth != null
                    && (request.auth.uid == uid
                        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "doctor");
        allow write: if request.auth.uid == uid
                     || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "doctor";
      }
    }

    // ── Surveys ───────────────────────────────────────────────────────────────
    // Any authenticated user can read surveys (doctor needs to see patient surveys).
    // Any authenticated user can submit a survey (patient submits their own).
    match /surveys/{surveyId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

  }
}
